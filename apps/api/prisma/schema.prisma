generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

enum AdminStatus {
  ACTIVE
  SUSPENDED
}

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  PACKED
  SHIPPED
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
  RETURN_REQUESTED
  RETURNED
  REFUNDED
}

enum PaymentMethod {
  COD
  SSLCOMMERZ
  BKASH
  CARD
}

enum PaymentStatus {
  PENDING
  AUTHORIZED
  PAID
  FAILED
  CANCELLED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum CouponType {
  PERCENTAGE
  FIXED_AMOUNT
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

enum InventoryMovementType {
  RESTOCK
  SALE
  CANCELLATION
  RETURN
  DAMAGE
  CORRECTION
  MANUAL_ADJUSTMENT
}

enum TokenSubjectType {
  CUSTOMER
  ADMIN
}

enum NotificationChannel {
  EMAIL
  SMS
  IN_APP
}

enum NotificationStatus {
  PENDING
  PROCESSING
  SENT
  FAILED
}

enum HomepageSectionType {
  HERO
  PROMOTIONAL
  FEATURED_CATEGORIES
  FEATURED_COLLECTIONS
  PRODUCT_RAIL
  BRAND_STORY
  GALLERY
}

model User {
  id                      String                   @id @default(cuid())
  email                   String                   @unique @db.VarChar(191)
  passwordHash            String
  name                    String                   @db.VarChar(120)
  phone                   String?                  @unique @db.VarChar(20)
  status                  UserStatus               @default(ACTIVE)
  emailVerifiedAt         DateTime?
  sessionVersion          Int                      @default(0)
  lastLoginAt             DateTime?
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  deletedAt               DateTime?
  addresses               CustomerAddress[]
  carts                   Cart[]
  wishlists               Wishlist[]
  orders                  Order[]
  couponUsages            CouponUsage[]
  reviews                 Review[]
  refreshTokens           RefreshToken[]
  passwordResetTokens     PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]
  notifications           Notification[]

  @@index([status, createdAt])
  @@map("users")
}

model CustomerAddress {
  id          String   @id @default(cuid())
  userId      String
  label       String   @default("Home") @db.VarChar(50)
  name        String   @db.VarChar(120)
  phone       String   @db.VarChar(20)
  division    String   @db.VarChar(80)
  district    String   @db.VarChar(80)
  area        String   @db.VarChar(120)
  addressLine String   @db.VarChar(500)
  postalCode  String?  @db.VarChar(20)
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isDefault])
  @@map("customer_addresses")
}

model AdminUser {
  id                  String               @id @default(cuid())
  email               String               @unique @db.VarChar(191)
  passwordHash        String
  name                String               @db.VarChar(120)
  status              AdminStatus          @default(ACTIVE)
  failedLoginAttempts Int                  @default(0)
  lockedUntil         DateTime?
  mfaSecretEncrypted  String?
  mfaEnabled          Boolean              @default(false)
  sessionVersion      Int                  @default(0)
  lastLoginAt         DateTime?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  deletedAt           DateTime?
  roles               AdminRole[]
  refreshTokens       RefreshToken[]
  inventoryMovements  InventoryMovement[]
  orderStatusChanges  OrderStatusHistory[]
  orderNotes          OrderInternalNote[]
  auditLogs           AuditLog[]

  @@index([status])
  @@map("admin_users")
}

model Role {
  id          String           @id @default(cuid())
  code        String           @unique @db.VarChar(80)
  name        String           @db.VarChar(120)
  description String?          @db.VarChar(500)
  isSystem    Boolean          @default(false)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  permissions RolePermission[]
  admins      AdminRole[]

  @@map("roles")
}

model Permission {
  id          String           @id @default(cuid())
  code        String           @unique @db.VarChar(120)
  description String?          @db.VarChar(500)
  roles       RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([permissionId])
  @@map("role_permissions")
}

model AdminRole {
  adminId String
  roleId  String
  admin   AdminUser @relation(fields: [adminId], references: [id], onDelete: Cascade)
  role    Role      @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([adminId, roleId])
  @@index([roleId])
  @@map("admin_roles")
}

model Category {
  id             String           @id @default(cuid())
  name           String           @db.VarChar(160)
  slug           String           @unique @db.VarChar(191)
  description    String?          @db.Text
  imageUrl       String?          @db.VarChar(1000)
  parentId       String?
  sortOrder      Int              @default(0)
  isActive       Boolean          @default(true)
  seoTitle       String?          @db.VarChar(160)
  seoDescription String?          @db.VarChar(320)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  archivedAt     DateTime?
  parent         Category?        @relation("CategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children       Category[]       @relation("CategoryTree")
  products       Product[]
  couponRules    CouponCategory[]

  @@index([parentId, sortOrder])
  @@index([isActive, sortOrder])
  @@map("categories")
}

model Collection {
  id             String              @id @default(cuid())
  name           String              @db.VarChar(160)
  slug           String              @unique @db.VarChar(191)
  description    String?             @db.Text
  bannerUrl      String?             @db.VarChar(1000)
  isFeatured     Boolean             @default(false)
  isActive       Boolean             @default(true)
  sortOrder      Int                 @default(0)
  seoTitle       String?             @db.VarChar(160)
  seoDescription String?             @db.VarChar(320)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  archivedAt     DateTime?
  products       CollectionProduct[]

  @@index([isActive, isFeatured, sortOrder])
  @@map("collections")
}

model CollectionProduct {
  collectionId String
  productId    String
  sortOrder    Int        @default(0)
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  product      Product    @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([collectionId, productId])
  @@index([productId])
  @@map("collection_products")
}

model Product {
  id               String              @id @default(cuid())
  categoryId       String
  name             String              @db.VarChar(200)
  slug             String              @unique @db.VarChar(191)
  skuPrefix        String?             @db.VarChar(60)
  brand            String?             @db.VarChar(160)
  productType      String?             @db.VarChar(160)
  vendor           String?             @db.VarChar(160)
  countryOfOrigin  String?             @db.VarChar(120)
  hsCode           String?             @db.VarChar(32)
  attributes       Json?
  shortDescription String?             @db.VarChar(500)
  description      String              @db.LongText
  regularPrice     Decimal             @db.Decimal(12, 2)
  salePrice        Decimal?            @db.Decimal(12, 2)
  saleStartsAt     DateTime?
  saleEndsAt       DateTime?
  status           ProductStatus       @default(DRAFT)
  isFeatured       Boolean             @default(false)
  isNewArrival     Boolean             @default(false)
  viewCount        Int                 @default(0)
  soldCount        Int                 @default(0)
  tags             Json
  seoTitle         String?             @db.VarChar(160)
  seoDescription   String?             @db.VarChar(320)
  createdByAdminId String?
  updatedByAdminId String?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  archivedAt       DateTime?
  category         Category            @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  images           ProductImage[]
  options          ProductOption[]
  variants         ProductVariant[]
  collections      CollectionProduct[]
  wishlistItems    WishlistItem[]
  reviews          Review[]
  couponRules      CouponProduct[]
  orderItems       OrderItem[]

  @@index([status, createdAt])
  @@index([categoryId, status])
  @@index([isFeatured, status])
  @@index([isNewArrival, status])
  @@index([soldCount, status])
  @@map("products")
}

model ProductImage {
  id        String           @id @default(cuid())
  productId String
  url       String           @db.VarChar(1000)
  objectKey String?          @db.VarChar(500)
  altText   String?          @db.VarChar(255)
  mimeType  String?          @db.VarChar(100)
  width     Int?
  height    Int?
  sortOrder Int              @default(0)
  isPrimary Boolean          @default(false)
  createdAt DateTime         @default(now())
  product   Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  variants  ProductVariant[]

  @@index([productId, sortOrder])
  @@map("product_images")
}

model ProductOption {
  id        String               @id @default(cuid())
  productId String
  name      String               @db.VarChar(80)
  sortOrder Int                  @default(0)
  product   Product              @relation(fields: [productId], references: [id], onDelete: Cascade)
  values    ProductOptionValue[]

  @@unique([productId, name])
  @@index([productId, sortOrder])
  @@map("product_options")
}

model ProductOptionValue {
  id        String               @id @default(cuid())
  optionId  String
  value     String               @db.VarChar(120)
  metadata  Json?
  sortOrder Int                  @default(0)
  option    ProductOption        @relation(fields: [optionId], references: [id], onDelete: Cascade)
  variants  VariantOptionValue[]

  @@unique([optionId, value])
  @@index([optionId, sortOrder])
  @@map("product_option_values")
}

model ProductVariant {
  id                 String               @id @default(cuid())
  productId          String
  sku                String               @unique @db.VarChar(100)
  barcode            String?              @unique @db.VarChar(100)
  priceOverride      Decimal?             @db.Decimal(12, 2)
  salePriceOverride  Decimal?             @db.Decimal(12, 2)
  saleStartsAt       DateTime?
  saleEndsAt         DateTime?
  stock              Int                  @default(0)
  lowStockThreshold  Int                  @default(5)
  weightGrams        Int?
  imageId            String?
  isActive           Boolean              @default(true)
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  archivedAt         DateTime?
  product            Product              @relation(fields: [productId], references: [id], onDelete: Restrict)
  image              ProductImage?        @relation(fields: [imageId], references: [id], onDelete: SetNull)
  optionValues       VariantOptionValue[]
  inventoryMovements InventoryMovement[]
  cartItems          CartItem[]
  wishlistItems      WishlistItem[]
  orderItems         OrderItem[]

  @@index([productId, isActive])
  @@index([stock, isActive])
  @@map("product_variants")
}

model VariantOptionValue {
  variantId String
  valueId   String
  variant   ProductVariant     @relation(fields: [variantId], references: [id], onDelete: Cascade)
  value     ProductOptionValue @relation(fields: [valueId], references: [id], onDelete: Restrict)

  @@id([variantId, valueId])
  @@index([valueId])
  @@map("variant_option_values")
}

model InventoryMovement {
  id             String                @id @default(cuid())
  variantId      String
  type           InventoryMovementType
  quantity       Int
  previousStock  Int
  newStock       Int
  reason         String?               @db.VarChar(500)
  orderId        String?
  adminId        String?
  restorationKey String?               @unique @db.VarChar(191)
  createdAt      DateTime              @default(now())
  variant        ProductVariant        @relation(fields: [variantId], references: [id], onDelete: Restrict)
  order          Order?                @relation(fields: [orderId], references: [id], onDelete: SetNull)
  admin          AdminUser?            @relation(fields: [adminId], references: [id], onDelete: SetNull)

  @@index([variantId, createdAt])
  @@index([orderId])
  @@index([type, createdAt])
  @@map("inventory_movements")
}

model Cart {
  id             String     @id @default(cuid())
  userId         String?
  guestTokenHash String?    @unique @db.Char(64)
  couponCode     String?    @db.VarChar(80)
  expiresAt      DateTime
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  user           User?      @relation(fields: [userId], references: [id], onDelete: Cascade)
  items          CartItem[]

  @@index([userId, updatedAt])
  @@index([expiresAt])
  @@map("carts")
}

model CartItem {
  id            String         @id @default(cuid())
  cartId        String
  variantId     String
  quantity      Int
  savedForLater Boolean        @default(false)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  cart          Cart           @relation(fields: [cartId], references: [id], onDelete: Cascade)
  variant       ProductVariant @relation(fields: [variantId], references: [id], onDelete: Restrict)

  @@unique([cartId, variantId])
  @@index([cartId, savedForLater])
  @@map("cart_items")
}

model Wishlist {
  id             String         @id @default(cuid())
  userId         String?
  guestTokenHash String?        @unique @db.Char(64)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  user           User?          @relation(fields: [userId], references: [id], onDelete: Cascade)
  items          WishlistItem[]

  @@unique([userId])
  @@map("wishlists")
}

model WishlistItem {
  id         String          @id @default(cuid())
  wishlistId String
  productId  String
  variantId  String?
  createdAt  DateTime        @default(now())
  wishlist   Wishlist        @relation(fields: [wishlistId], references: [id], onDelete: Cascade)
  product    Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant    ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@unique([wishlistId, productId])
  @@index([productId])
  @@map("wishlist_items")
}

model Order {
  id                      String               @id @default(cuid())
  orderNumber             String               @unique @db.VarChar(40)
  customerId              String?
  customerName            String               @db.VarChar(120)
  customerPhone           String               @db.VarChar(20)
  customerEmail           String?              @db.VarChar(191)
  addressSnapshot         Json
  deliveryZone            String               @db.VarChar(80)
  deliveryCharge          Decimal              @db.Decimal(12, 2)
  subtotal                Decimal              @db.Decimal(12, 2)
  productDiscount         Decimal              @default(0) @db.Decimal(12, 2)
  couponDiscount          Decimal              @default(0) @db.Decimal(12, 2)
  grandTotal              Decimal              @db.Decimal(12, 2)
  couponId                String?
  couponCode              String?              @db.VarChar(80)
  paymentMethod           PaymentMethod        @default(COD)
  paymentStatus           PaymentStatus        @default(PENDING)
  status                  OrderStatus          @default(PENDING)
  publicTrackingTokenHash String               @unique @db.Char(64)
  stockRestoredAt         DateTime?
  placedAt                DateTime             @default(now())
  updatedAt               DateTime             @updatedAt
  customer                User?                @relation(fields: [customerId], references: [id], onDelete: SetNull)
  coupon                  Coupon?              @relation(fields: [couponId], references: [id], onDelete: SetNull)
  items                   OrderItem[]
  statusHistory           OrderStatusHistory[]
  internalNotes           OrderInternalNote[]
  payments                Payment[]
  couponUsages            CouponUsage[]
  inventoryMovements      InventoryMovement[]
  idempotencyKeys         IdempotencyKey[]
  reviews                 Review[]

  @@index([customerId, placedAt])
  @@index([customerPhone, placedAt])
  @@index([status, placedAt])
  @@index([paymentStatus, placedAt])
  @@map("orders")
}

model OrderItem {
  id                     String          @id @default(cuid())
  orderId                String
  productId              String?
  variantId              String?
  productNameSnapshot    String          @db.VarChar(200)
  productSlugSnapshot    String          @db.VarChar(191)
  productSkuSnapshot     String?         @db.VarChar(100)
  variantSkuSnapshot     String          @db.VarChar(100)
  variantDetailsSnapshot Json
  imageUrlSnapshot       String?         @db.VarChar(1000)
  regularUnitPrice       Decimal         @db.Decimal(12, 2)
  unitPrice              Decimal         @db.Decimal(12, 2)
  unitDiscount           Decimal         @default(0) @db.Decimal(12, 2)
  quantity               Int
  lineTotal              Decimal         @db.Decimal(12, 2)
  order                  Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product                Product?        @relation(fields: [productId], references: [id], onDelete: SetNull)
  variant                ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  review                 Review?

  @@index([orderId])
  @@index([productId])
  @@index([variantId])
  @@map("order_items")
}

model OrderStatusHistory {
  id             String       @id @default(cuid())
  orderId        String
  previousStatus OrderStatus?
  newStatus      OrderStatus
  actorType      String       @db.VarChar(30)
  actorId        String?
  adminId        String?
  note           String?      @db.VarChar(1000)
  createdAt      DateTime     @default(now())
  order          Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  admin          AdminUser?   @relation(fields: [adminId], references: [id], onDelete: SetNull)

  @@index([orderId, createdAt])
  @@map("order_status_history")
}

model OrderInternalNote {
  id        String    @id @default(cuid())
  orderId   String
  adminId   String
  note      String    @db.Text
  createdAt DateTime  @default(now())
  order     Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  admin     AdminUser @relation(fields: [adminId], references: [id], onDelete: Restrict)

  @@index([orderId, createdAt])
  @@map("order_internal_notes")
}

model Payment {
  id                String           @id @default(cuid())
  orderId           String
  method            PaymentMethod
  provider          String           @db.VarChar(60)
  amount            Decimal          @db.Decimal(12, 2)
  refundedAmount    Decimal          @default(0) @db.Decimal(12, 2)
  status            PaymentStatus    @default(PENDING)
  providerReference String?          @unique @db.VarChar(191)
  metadata          Json?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  order             Order            @relation(fields: [orderId], references: [id], onDelete: Restrict)
  attempts          PaymentAttempt[]

  @@index([orderId, createdAt])
  @@index([status, createdAt])
  @@map("payments")
}

model PaymentAttempt {
  id                String        @id @default(cuid())
  paymentId         String
  status            PaymentStatus
  providerReference String?       @db.VarChar(191)
  requestMetadata   Json?
  responseMetadata  Json?
  failureCode       String?       @db.VarChar(100)
  createdAt         DateTime      @default(now())
  payment           Payment       @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([paymentId, createdAt])
  @@map("payment_attempts")
}

model Coupon {
  id                    String           @id @default(cuid())
  code                  String           @unique @db.VarChar(80)
  type                  CouponType
  value                 Decimal          @db.Decimal(12, 2)
  minimumSpend          Decimal?         @db.Decimal(12, 2)
  maximumDiscount       Decimal?         @db.Decimal(12, 2)
  totalUsageLimit       Int?
  perCustomerUsageLimit Int?
  startsAt              DateTime
  expiresAt             DateTime
  firstOrderOnly        Boolean          @default(false)
  isActive              Boolean          @default(true)
  createdByAdminId      String?
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
  archivedAt            DateTime?
  products              CouponProduct[]
  categories            CouponCategory[]
  orders                Order[]
  usages                CouponUsage[]

  @@index([isActive, startsAt, expiresAt])
  @@map("coupons")
}

model CouponProduct {
  couponId  String
  productId String
  coupon    Coupon  @relation(fields: [couponId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([couponId, productId])
  @@index([productId])
  @@map("coupon_products")
}

model CouponCategory {
  couponId   String
  categoryId String
  coupon     Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([couponId, categoryId])
  @@index([categoryId])
  @@map("coupon_categories")
}

model CouponUsage {
  id       String   @id @default(cuid())
  couponId String
  userId   String?
  orderId  String
  guestKey String?  @db.VarChar(100)
  usedAt   DateTime @default(now())
  coupon   Coupon   @relation(fields: [couponId], references: [id], onDelete: Restrict)
  user     User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  order    Order    @relation(fields: [orderId], references: [id], onDelete: Restrict)

  @@unique([couponId, orderId])
  @@index([couponId, userId])
  @@index([couponId, guestKey])
  @@map("coupon_usages")
}

model Review {
  id                 String       @id @default(cuid())
  productId          String
  userId             String
  orderId            String
  orderItemId        String       @unique
  rating             Int
  title              String?      @db.VarChar(160)
  body               String       @db.Text
  status             ReviewStatus @default(PENDING)
  isVerifiedPurchase Boolean      @default(true)
  moderatedByAdminId String?
  moderatedAt        DateTime?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  product            Product      @relation(fields: [productId], references: [id], onDelete: Restrict)
  user               User         @relation(fields: [userId], references: [id], onDelete: Restrict)
  order              Order        @relation(fields: [orderId], references: [id], onDelete: Restrict)
  orderItem          OrderItem    @relation(fields: [orderItemId], references: [id], onDelete: Restrict)

  @@index([productId, status, createdAt])
  @@index([userId, createdAt])
  @@map("reviews")
}

model Banner {
  id             String    @id @default(cuid())
  title          String    @db.VarChar(200)
  subtitle       String?   @db.VarChar(500)
  imageUrl       String    @db.VarChar(1000)
  mobileImageUrl String?   @db.VarChar(1000)
  linkUrl        String?   @db.VarChar(1000)
  location       String    @default("HOME_HERO") @db.VarChar(80)
  sortOrder      Int       @default(0)
  isActive       Boolean   @default(true)
  startsAt       DateTime?
  endsAt         DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([location, isActive, sortOrder])
  @@map("banners")
}

model HomepageSection {
  id        String              @id @default(cuid())
  type      HomepageSectionType
  title     String?             @db.VarChar(200)
  config    Json
  sortOrder Int                 @default(0)
  isVisible Boolean             @default(true)
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  @@index([isVisible, sortOrder])
  @@map("homepage_sections")
}

model SiteSetting {
  id               String   @id @default(cuid())
  key              String   @unique @db.VarChar(191)
  value            Json
  isPublic         Boolean  @default(false)
  updatedByAdminId String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([isPublic])
  @@map("site_settings")
}

model Notification {
  id          String              @id @default(cuid())
  userId      String?
  channel     NotificationChannel
  template    String              @db.VarChar(100)
  recipient   String              @db.VarChar(191)
  subject     String?             @db.VarChar(255)
  payload     Json
  status      NotificationStatus  @default(PENDING)
  attempts    Int                 @default(0)
  availableAt DateTime            @default(now())
  sentAt      DateTime?
  lastError   String?             @db.VarChar(1000)
  createdAt   DateTime            @default(now())
  user        User?               @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([status, availableAt])
  @@index([userId, createdAt])
  @@map("notifications")
}

model NewsletterSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique @db.VarChar(191)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, createdAt])
  @@map("newsletter_subscribers")
}

model ContactSubmission {
  id        String   @id @default(cuid())
  name      String   @db.VarChar(120)
  email     String   @db.VarChar(191)
  subject   String?  @db.VarChar(200)
  message   String   @db.Text
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([email, createdAt])
  @@map("contact_submissions")
}

model AuditLog {
  id            String     @id @default(cuid())
  adminId       String?
  action        String     @db.VarChar(120)
  entityType    String     @db.VarChar(100)
  entityId      String?    @db.VarChar(191)
  previousValue Json?
  newValue      Json?
  requestId     String?    @db.VarChar(100)
  ipAddress     String?    @db.VarChar(64)
  userAgent     String?    @db.VarChar(500)
  createdAt     DateTime   @default(now())
  admin         AdminUser? @relation(fields: [adminId], references: [id], onDelete: SetNull)

  @@index([adminId, createdAt])
  @@index([entityType, entityId, createdAt])
  @@index([action, createdAt])
  @@map("audit_logs")
}

model RefreshToken {
  id                String           @id @default(cuid())
  familyId          String           @db.VarChar(191)
  tokenHash         String           @unique @db.Char(64)
  subjectType       TokenSubjectType
  userId            String?
  adminId           String?
  sessionVersion    Int
  expiresAt         DateTime
  usedAt            DateTime?
  revokedAt         DateTime?
  replacedByTokenId String?
  createdByIp       String?          @db.VarChar(64)
  userAgent         String?          @db.VarChar(500)
  createdAt         DateTime         @default(now())
  user              User?            @relation(fields: [userId], references: [id], onDelete: Cascade)
  admin             AdminUser?       @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([familyId])
  @@index([userId, expiresAt])
  @@index([adminId, expiresAt])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique @db.Char(64)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@map("password_reset_tokens")
}

model EmailVerificationToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique @db.Char(64)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@map("email_verification_tokens")
}

model IdempotencyKey {
  id           String    @id @default(cuid())
  scope        String    @db.VarChar(100)
  keyHash      String    @db.Char(64)
  requestHash  String    @db.Char(64)
  userId       String?
  guestKey     String?   @db.VarChar(100)
  statusCode   Int?
  responseBody Json?
  orderId      String?
  lockedUntil  DateTime?
  expiresAt    DateTime
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  order        Order?    @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@unique([scope, keyHash])
  @@index([expiresAt])
  @@index([userId, createdAt])
  @@map("idempotency_keys")
}
