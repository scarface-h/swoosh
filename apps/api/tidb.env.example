# Copy the DATABASE_URL below into apps/api/.env.
# Replace URL_ENCODED_PASSWORD with the TiDB Cloud password.
# Password characters such as @, :, /, ?, # and % must be percent-encoded.
DATABASE_URL="mysql://wFZbY3XLgvSDtV1.root:URL_ENCODED_PASSWORD@gateway01.ap-southeast-1.prod.aws.tidbcloud.com:4000/ecommerce?sslaccept=strict"

# TiDB Cloud public endpoints require TLS. sslaccept=strict enables certificate validation.
# If TiDB provides a separate CA file and your system does not already trust it:
# 1. Save it as apps/api/prisma/ca.pem (PEM files are gitignored).
# 2. Append &sslcert=ca.pem to DATABASE_URL.
