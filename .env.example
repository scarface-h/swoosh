# Runtime
NODE_ENV=development
PORT=4000
APP_VERSION=dev
LOG_LEVEL=info

# MySQL-compatible database (use a least-privilege application account)
DATABASE_URL="mysql://USERNAME:PASSWORD@HOST:3306/DATABASE"
# TiDB Cloud example:
# DATABASE_URL="mysql://wFZbY3XLgvSDtV1.root:URL_ENCODED_PASSWORD@gateway01.ap-southeast-1.prod.aws.tidbcloud.com:4000/ecommerce?sslaccept=strict"
MYSQL_DATABASE=swoosh
MYSQL_USER=swoosh_user
MYSQL_PASSWORD=change-me
MYSQL_ROOT_PASSWORD=change-root-password

# Redis (rate-limit/cache/queue coordination; persistent data remains in MySQL)
REDIS_URL=redis://localhost:6379

# Authentication (generate independent random values of at least 32 bytes)
ACCESS_TOKEN_SECRET=replace-with-a-unique-32-byte-random-secret
REFRESH_TOKEN_SECRET=replace-with-another-unique-32-byte-random-secret
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d
COOKIE_DOMAIN=
CORS_ORIGINS=http://localhost:5173,http://localhost:5174
STOREFRONT_URL=http://localhost:5173
ADMIN_URL=http://localhost:5174

# One-time/bootstrap seed credentials (change immediately outside local development)
INITIAL_ADMIN_EMAIL=admin@swoosh.local
INITIAL_ADMIN_PASSWORD=ChangeMeNow!2026

# S3-compatible image storage
S3_ENDPOINT=
S3_REGION=auto
S3_BUCKET=swoosh-images
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
CDN_BASE_URL=

# Cloudinary image storage (preferred for ephemeral hosting such as Render)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Email notifications
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=Swoosh <no-reply@example.com>

# Error monitoring
SENTRY_DSN=

# Backup scripts
BACKUP_DIRECTORY=./backups
BACKUP_RETENTION_DAYS=14
BACKUP_ENCRYPTION_PASSPHRASE=
